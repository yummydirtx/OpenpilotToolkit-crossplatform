<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:theme="clr-namespace:Avalonia.Themes.Fluent;assembly=Avalonia.Themes.Fluent"
             x:Class="OpenpilotToolkit.Avalonia.App"
             RequestedThemeVariant="Dark">
  <Application.Styles>
    <theme:FluentTheme DensityStyle="Compact" />

    <Style Selector="Window">
      <Setter Property="Background" Value="#14171D" />
      <Setter Property="Foreground" Value="#EAF1F7" />
      <Setter Property="FontFamily" Value="Noto Sans, Segoe UI, Arial" />
    </Style>

    <Style Selector="Border.topbar">
      <Setter Property="Background" Value="#21252C" />
      <Setter Property="BorderBrush" Value="#2E343D" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Border.shell-frame">
      <Setter Property="Background" Value="#1A1E25" />
      <Setter Property="BorderBrush" Value="#303742" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="Padding" Value="12" />
    </Style>

    <Style Selector="Border.navigation-pane">
      <Setter Property="Background" Value="#151A21" />
      <Setter Property="BorderBrush" Value="#303742" />
      <Setter Property="BorderThickness" Value="0,0,1,0" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Padding" Value="10" />
    </Style>

    <Style Selector="Border.surface-panel">
      <Setter Property="Background" Value="#232932" />
      <Setter Property="BorderBrush" Value="#353D48" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="18" />
    </Style>

    <Style Selector="Border.route-card">
      <Setter Property="Background" Value="#1B2028" />
      <Setter Property="BorderBrush" Value="#313844" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="14" />
    </Style>

    <Style Selector="Border.placeholder-panel">
      <Setter Property="Background" Value="#181C22" />
      <Setter Property="BorderBrush" Value="#38404C" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="22" />
    </Style>

    <Style Selector="Border.status-chip">
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Padding" Value="12 7" />
      <Setter Property="MinWidth" Value="96" />
    </Style>

    <Style Selector="Border.inline-chip">
      <Setter Property="Background" Value="#2B3340" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Padding" Value="10 4" />
      <Setter Property="MinWidth" Value="48" />
    </Style>

    <Style Selector="Border.nav-abbrev">
      <Setter Property="Background" Value="#2C3542" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Width" Value="40" />
      <Setter Property="Height" Value="40" />
    </Style>

    <Style Selector="TextBlock.window-title">
      <Setter Property="FontSize" Value="22" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="#F5FAFF" />
    </Style>

    <Style Selector="TextBlock.window-subtitle">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="#8E9AAA" />
    </Style>

    <Style Selector="TextBlock.toolbar-label">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="#B5C0CC" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="17" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#F0F5FB" />
    </Style>

    <Style Selector="TextBlock.card-title">
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#F0F5FB" />
    </Style>

    <Style Selector="TextBlock.panel-title">
      <Setter Property="FontSize" Value="24" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="#F6FBFF" />
    </Style>

    <Style Selector="TextBlock.caption">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="#99A4B2" />
    </Style>

    <Style Selector="TextBlock.form-label">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="#8B96A6" />
      <Setter Property="Margin" Value="0,0,12,0" />
    </Style>

    <Style Selector="TextBlock.placeholder-note">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="#7F8C9A" />
      <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.status-text">
      <Setter Property="Foreground" Value="#F7FBFF" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style Selector="TextBlock.nav-abbrev-text">
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="#D7E2EF" />
    </Style>

    <Style Selector="Button">
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="Background" Value="#2D3440" />
      <Setter Property="Foreground" Value="#F0F5FB" />
      <Setter Property="BorderBrush" Value="#434C5B" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button:disabled">
      <Setter Property="Opacity" Value="0.55" />
    </Style>

    <Style Selector="Button.accent">
      <Setter Property="Background" Value="#29B6F6" />
      <Setter Property="Foreground" Value="#05131D" />
      <Setter Property="BorderBrush" Value="#29B6F6" />
    </Style>

    <Style Selector="Button.large-action">
      <Setter Property="MinHeight" Value="54" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.toolbar-action">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="14 6" />
    </Style>

    <Style Selector="Button.nav-toggle">
      <Setter Property="Width" Value="40" />
      <Setter Property="MinHeight" Value="40" />
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style Selector="ListBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0 0 0 10" />
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ListBoxItem:pointerover Border.route-card">
      <Setter Property="Background" Value="#212732" />
      <Setter Property="BorderBrush" Value="#4B5565" />
    </Style>

    <Style Selector="ListBoxItem:selected Border.route-card">
      <Setter Property="Background" Value="#0F3E57" />
      <Setter Property="BorderBrush" Value="#29B6F6" />
    </Style>

    <Style Selector="ListBox.nav-list">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="ListBoxItem.nav-item">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0 0 0 8" />
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="Border.nav-item-shell">
      <Setter Property="Background" Value="#1E242D" />
      <Setter Property="BorderBrush" Value="#303743" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Padding" Value="12" />
      <Setter Property="MinHeight" Value="64" />
    </Style>

    <Style Selector="TextBlock.nav-item-title">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#F0F5FB" />
    </Style>

    <Style Selector="TextBlock.nav-item-subtitle">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="#8E9AAA" />
    </Style>

    <Style Selector="ListBoxItem.nav-item:pointerover Border.nav-item-shell">
      <Setter Property="Background" Value="#242B35" />
      <Setter Property="BorderBrush" Value="#445061" />
    </Style>

    <Style Selector="ListBoxItem.nav-item:selected Border.nav-item-shell">
      <Setter Property="Background" Value="#29B6F6" />
      <Setter Property="BorderBrush" Value="#29B6F6" />
    </Style>

    <Style Selector="ListBoxItem.nav-item:selected TextBlock.nav-item-title">
      <Setter Property="Foreground" Value="#081620" />
    </Style>

    <Style Selector="ListBoxItem.nav-item:selected TextBlock.nav-item-subtitle">
      <Setter Property="Foreground" Value="#14384C" />
    </Style>

    <Style Selector="ListBoxItem.nav-item:selected Border.nav-abbrev">
      <Setter Property="Background" Value="#0A1A24" />
    </Style>

    <Style Selector="TabControl">
      <Setter Property="Background" Value="#1A1E25" />
    </Style>

    <Style Selector="TabItem">
      <Setter Property="Foreground" Value="#DDE6F0" />
      <Setter Property="Padding" Value="12" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>

    <Style Selector="TabItem.shell-tab">
      <Setter Property="Margin" Value="0 0 8 8" />
      <Setter Property="MinHeight" Value="72" />
      <Setter Property="Background" Value="#21262F" />
      <Setter Property="BorderBrush" Value="#303743" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="TabItem.shell-tab:selected">
      <Setter Property="Background" Value="#29B6F6" />
      <Setter Property="BorderBrush" Value="#29B6F6" />
    </Style>

    <Style Selector="TabItem.shell-tab:selected TextBlock.card-title">
      <Setter Property="Foreground" Value="#07131C" />
    </Style>

    <Style Selector="TabItem.shell-tab:selected TextBlock.caption">
      <Setter Property="Foreground" Value="#123346" />
    </Style>

    <Style Selector="TabItem.shell-tab:selected Border.nav-abbrev">
      <Setter Property="Background" Value="#0A1A24" />
    </Style>

    <Style Selector="TextBox">
      <Setter Property="Background" Value="#161A21" />
      <Setter Property="Foreground" Value="#ECF3F8" />
      <Setter Property="BorderBrush" Value="#3D4552" />
    </Style>

    <Style Selector="ComboBox">
      <Setter Property="Background" Value="#161A21" />
      <Setter Property="Foreground" Value="#ECF3F8" />
      <Setter Property="BorderBrush" Value="#3D4552" />
    </Style>

    <Style Selector="CheckBox">
      <Setter Property="Foreground" Value="#DDE6F0" />
    </Style>

    <Style Selector="TextBox.log-console">
      <Setter Property="FontFamily" Value="JetBrains Mono, Cascadia Mono, Consolas" />
      <Setter Property="Background" Value="#0F1217" />
      <Setter Property="Foreground" Value="#E4EDF5" />
      <Setter Property="BorderBrush" Value="#313844" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
  </Application.Styles>
</Application>
